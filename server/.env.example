PORT=3001

# Database (Supabase PostgreSQL)
DB_HOST=your-supabase-host.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_SSL=true
DATABASE_URL=postgresql://postgres:your-password-here@db.xxx.supabase.co:5432/postgres

# Auth
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

# AI Assistant Configuration (choose one or both)
# Option A: Direct OpenAI-compatible API (OpenAI, local LLM, LM Studio, Ollama, etc.)
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# Option B: OpenClaw Gateway (routes through your OpenClaw agent)
# Find your gateway token: grep token ~/.openclaw/openclaw.json
# OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token-here
# OPENCLAW_AI_MODEL=deepseek/deepseek-v4-flash

NODE_ENV=development
